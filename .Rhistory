legend("topright", legend = c("Sample", "Theoretical"),
col = c("lightblue", "red"), lwd = 2, bcex = 0.8)
}
}
for (n in ns) {
# Generate sample means:
# For each replicate, generate n Cauchy variables and take their mean
# We use replicate() to repeat the process
yn <- replicate(replicates, mean(rcauchy(n)))
# Plot histogram
hist(yn, breaks = 100, probability = TRUE, xlim = c(-10, 10),
main = paste("n =", n), xlab = expression(Y[n]),
col = "lightblue", border = "white")
# Add the theoretical standard Cauchy PDF for comparison
curve(dcauchy(x), add = TRUE, col = "red", lwd = 2)
if (n == ns[1]) {
legend("topright", legend = c("Sample", "Theoretical"),
col = c("lightblue", "red"), lwd = 2, bcex = 0.8)
}
}
